rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the database is unseeded (profile/info does not exist yet)
    function isUnseeded() {
      return !exists(/databases/$(database)/documents/profile/info);
    }

    // Anyone can read profile details, projects, skills, certificates, experience, education, gallery, and settings.
    match /profile/{document} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }
    match /projects/{document} {
      allow read: if true;
      allow create, update: if request.auth != null || isUnseeded();
      allow delete: if request.auth != null;
    }
    match /skills/{document} {
      allow read: if true;
      allow create, update: if request.auth != null || isUnseeded();
      allow delete: if request.auth != null;
    }
    match /certificates/{document} {
      allow read: if true;
      allow create, update: if request.auth != null || isUnseeded();
      allow delete: if request.auth != null;
    }
    match /gallery/{document} {
      allow read: if true;
      allow create, update: if request.auth != null || isUnseeded();
      allow delete: if request.auth != null;
    }
    match /experience/{document} {
      allow read: if true;
      allow create, update: if request.auth != null || isUnseeded();
      allow delete: if request.auth != null;
    }
    match /education/{document} {
      allow read: if true;
      allow create, update: if request.auth != null || isUnseeded();
      allow delete: if request.auth != null;
    }
    match /settings/{document} {
      allow read: if true;
      allow create, update: if request.auth != null || isUnseeded();
      allow delete: if request.auth != null;
    }

    // Anyone can create a new contact message. Only authenticated admins can read, update, or delete messages.
    match /contact_messages/{document} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
