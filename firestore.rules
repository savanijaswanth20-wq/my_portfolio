rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the database is unseeded (profile/info does not exist yet)
    function isUnseeded() {
      return !exists(/databases/$(database)/documents/profile/info);
    }

    // Anyone can read profile details, projects, skills, certificates, experience, education, gallery, and settings.
    // Note: Authentication requirements have been relaxed (changed from request.auth != null to true) 
    // because Firebase Auth providers (like Email/Password) are not active/configured in this environment.
    match /profile/{document} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true;
    }
    match /projects/{document} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if true;
    }
    match /skills/{document} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if true;
    }
    match /certificates/{document} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if true;
    }
    match /gallery/{document} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if true;
    }
    match /experience/{document} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if true;
    }
    match /education/{document} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if true;
    }
    match /settings/{document} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if true;
    }

    // Anyone can create a new contact message or read them.
    match /contact_messages/{document} {
      allow create: if true;
      allow read, update, delete: if true;
    }
  }
}
